# Primary analysis model. Free-tier key works; the pipeline waits out rate limits.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=

# Used as a fallback when the Gemini quota is exhausted, and for Whisper
# transcription of Instagram Reels. Optional for YouTube-only runs.
OPENAI_API_KEY=

# Required only for Instagram ingestion (runs apify/instagram-profile-scraper
# and apify/instagram-comment-scraper). https://console.apify.com/account/integrations
APIFY_TOKEN=
